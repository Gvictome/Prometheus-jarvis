# ─── Shared Postgres (Neon) ───────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── Shared Secrets ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENCLAW_SECRET_KEY=change-me-to-random-string

# ─── Inference ────────────────────────────────────────────────────────────────
OPENROUTER_MAX_TOKENS=4096
OLLAMA_BASE_URL=http://host.docker.internal:11434
INFERENCE_COMPLEXITY_THRESHOLD=0.6
INFERENCE_MONTHLY_BUDGET_USD=50.00

# ─── Bot Tokens (create each via @BotFather on Telegram) ──────────────────────
KENDALL_BOT_TOKEN=
DYMANI_BOT_TOKEN=
CHRIS_BOT_TOKEN=

# ─── Security ─────────────────────────────────────────────────────────────────
ADMIN_USER_IDS=[]
ADMIN_PIN=0000
